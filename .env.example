# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is gitignored — never commit it.
# ============================================================


# ============================================================
# DOMAIN CONFIGURATION
# ============================================================
# This controls what domain appears in generated job page URLs
# and Telegram broadcast messages.
#
# --- Local development ---
# Leave this commented out or set it to localhost.
# The server defaults to localhost:3000 when APP_DOMAIN is not set.
#
# APP_DOMAIN=localhost:3000
#
# --- Production ---
# Set this to your real domain (no https://, no trailing slash).
#
# APP_DOMAIN=yourjobs.com
#
# How it works:
#   - On first run, config.json is created using this value as the domain.
#   - If you change APP_DOMAIN later, the server updates config.json on the
#     next startup so all job page links reflect the new domain.
#   - You can also change the domain any time from the Settings panel in the UI.

APP_DOMAIN=localhost:3000


# ============================================================
# SERVER PORT
# ============================================================
# The port the Express server listens on.
# Default is 3000. Change this if something else is already using 3000.

PORT=3000


# ============================================================
# AI PROVIDER CONFIGURATION
# Pick ONE provider and set its key. The rest can stay commented out.
# ============================================================

# Which provider to use.
# Options: gemini | openai | groq | openrouter | ollama
# If not set, the server auto-detects based on which key is present.
AI_PROVIDER=gemini


# --- Google Gemini (FREE tier — recommended for getting started) ---
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash    # optional — this is the default


# --- Groq (FREE tier — very fast, uses open LLaMA models) ---
# Get a key at: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile    # optional


# --- OpenRouter (has free models available) ---
# Get a key at: https://openrouter.ai/keys
# Free model options: meta-llama/llama-3.1-8b-instruct:free
#                     google/gemma-3-4b-it:free
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free    # optional


# --- OpenAI (paid, but gpt-4o-mini is very cheap) ---
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini    # optional


# --- Ollama (completely free — runs models locally, no internet needed) ---
# Install Ollama: https://ollama.ai
# Then pull a model: ollama pull llama3.2
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434    # optional
# OLLAMA_MODEL=llama3.2                    # optional
