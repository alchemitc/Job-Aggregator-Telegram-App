# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is gitignored — never commit it.
# ============================================================


# ============================================================
# DOMAIN CONFIGURATION
# ============================================================
# Controls what domain appears in generated job page URLs
# and Telegram broadcast messages.
#
# Dev:  APP_DOMAIN=localhost:3000  (default if not set)
# Prod: APP_DOMAIN=yourjobs.com

APP_DOMAIN=localhost:3000


# ============================================================
# SERVER PORT
# ============================================================
# Default is 3000.

PORT=3000


# ============================================================
# TELEGRAM BOT CREDENTIALS
# ============================================================
# Your bot token and channel username/ID.
# These are used when you click "Post to Telegram" in the admin panel.
# You can also set them via Settings in the UI — but setting them here
# means they survive a server restart without needing to re-enter them.
#
# How to get your bot token:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the token it gives you (looks like: 123456789:ABCdef...)
#
# How to get your channel ID:
#   Option A — use the username:  @yourchannelname
#   Option B — use the numeric ID: -1001234567890
#   (To find the numeric ID, forward a message from your channel to
#    @userinfobot or @getidsbot)
#
# IMPORTANT: Your bot must be an admin of the channel with "Post Messages"
# permission before it can send posts there.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=


# ============================================================
# AUTO-CRAWL SCHEDULER
# ============================================================
# The server can automatically crawl the Telegram channel every N hours
# and ingest any new job posts it finds.
#
# Auto-crawl does NOT auto-post to your Telegram channel.
# Posting always requires you to manually approve and click "Post" in the
# admin panel — this is intentional so you can review before publishing.
#
# Set AUTO_CRAWL=true to enable. Set AUTO_CRAWL_INTERVAL_HOURS to control
# how often it runs (default: 4 hours).

AUTO_CRAWL=true
AUTO_CRAWL_INTERVAL_HOURS=4


# ============================================================
# AI PROVIDER CONFIGURATION
# Pick ONE provider and set its key.
# ============================================================

# Which provider to use.
# Options: gemini | openai | groq | openrouter | ollama
# If not set, auto-detected from whichever key is present.
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier — recommended) ---
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash    # optional

# --- Groq (FREE tier — very fast LLaMA models) ---
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (free models available) ---
# Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- OpenAI (paid, gpt-4o-mini is cheapest) ---
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama (free, runs locally) ---
# Install: https://ollama.ai  then: ollama pull llama3.2
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
