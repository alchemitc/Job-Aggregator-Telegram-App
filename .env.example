# ============================================================
# AI Provider Configuration - Pick ONE and set its key
# ============================================================

# Which provider to use (auto-detected if not set)
# Options: gemini | openai | groq | openrouter | ollama
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier - recommended) ---
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash   # optional, this is default

# --- Groq (FREE tier - very fast, uses LLaMA/Mixtral) ---
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # optional

# --- OpenRouter (FREE models available) ---
# Get key: https://openrouter.ai/keys
# Free models: meta-llama/llama-3.1-8b-instruct:free, google/gemma-3-4b-it:free
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free  # optional

# --- OpenAI (GPT - Paid but cheap with gpt-4o-mini) ---
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini   # optional

# --- Ollama (Local - completely FREE, no internet needed) ---
# Install: https://ollama.ai  then run: ollama pull llama3.2
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434   # optional
# OLLAMA_MODEL=llama3.2   # optional

# ============================================================
# App Config (optional - can also set via UI)
# ============================================================
# NODE_ENV=development
